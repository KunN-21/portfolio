---
import MagneticCTA from "./MagneticCTA";
---

<section class="relative min-h-[100dvh] flex items-center pt-20 pb-24 px-6 md:px-10 lg:px-16 overflow-hidden">
  <!-- Left: text stack -->
  <div class="relative z-10 max-w-2xl">
    <p class="hero-anim-1 inline-block text-sm font-mono uppercase tracking-[0.3em] text-accent mb-6 opacity-0 translate-y-3">
      AI Engineer · RAG · Computer Vision
    </p>
    <h1
      id="hero-title"
      class="hero-anim-2 text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter leading-[1.05] text-zinc-900 dark:text-zinc-100 mb-6 max-w-[12ch] opacity-0 translate-y-6"
    >
      Vu Khanh Nam
    </h1>
    <p class="hero-anim-3 text-lg md:text-xl text-zinc-600 dark:text-zinc-400 max-w-[40ch] leading-relaxed mb-10 opacity-0 translate-y-4">
      Building RAG systems and computer vision pipelines that ship. Hybrid retrieval, multi-LLM orchestration, custom YOLO detectors - from research to production.
    </p>
    <div class="hero-anim-4 flex flex-wrap gap-4 opacity-0 translate-y-3">
      <MagneticCTA
        href="https://github.com/KunN-21"
        variant="primary"
        external
        client:visible
      >
        <span>View GitHub</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </MagneticCTA>
      <MagneticCTA
        href="mailto:vukhanhnam.nv@gmail.com"
        variant="outline"
        client:visible
      >
        Get in touch
      </MagneticCTA>
    </div>
  </div>

  <!-- Right: composed tech visual -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 hidden md:block w-[46%] min-w-[380px] max-w-[560px] aspect-square pointer-events-none hero-anim-5 opacity-0" aria-hidden="true">
    <!-- aurora glow behind -->
    <div class="absolute inset-0 rounded-full blur-3xl" style="background: radial-gradient(circle at 50% 50%, rgba(59,130,246,0.28) 0%, rgba(20,184,166,0.16) 45%, transparent 70%);"></div>

    <!-- terminal window -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[78%] max-w-[440px] rounded-xl overflow-hidden border border-zinc-200/70 dark:border-zinc-700/70 bg-white/90 dark:bg-zinc-900/90 backdrop-blur-md shadow-2xl">
      <div class="flex items-center gap-1.5 px-3 py-2 bg-zinc-100/90 dark:bg-zinc-800/90 border-b border-zinc-200/70 dark:border-zinc-700/70">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
        <span class="ml-3 text-[10px] font-mono text-zinc-500">rag_pipeline.py</span>
      </div>
      <div class="p-4 font-mono text-[11px] leading-relaxed text-zinc-700 dark:text-zinc-300">
        <div><span class="text-purple-600 dark:text-purple-400">from</span> rag <span class="text-purple-600 dark:text-purple-400">import</span> HybridRetriever</div>
        <div class="mt-1 text-zinc-500"><span class="text-zinc-400 dark:text-zinc-600"># vector + BM25</span></div>
        <div>r = <span class="text-blue-600 dark:text-blue-400">HybridRetriever</span>(α=<span class="text-amber-600 dark:text-amber-300">0.6</span>)</div>
        <div class="mt-1">docs = r.search(query)</div>
        <div>answer = llm.<span class="text-blue-600 dark:text-blue-400">generate</span>(docs)</div>
        <div class="mt-2 pt-2 border-t border-zinc-200/70 dark:border-zinc-700/70 flex items-center gap-2 text-zinc-500">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-teal-500 animate-pulse"></span>
          <span>agent loop active</span>
        </div>
      </div>
    </div>

    <!-- orbiting tech badges -->
    <div class="absolute top-[8%] left-[6%] float-badge" style="animation-delay: 0s;">
      <span class="px-3 py-1.5 rounded-full bg-white/90 dark:bg-zinc-800/90 border border-zinc-200/60 dark:border-zinc-700/60 text-xs font-mono text-zinc-700 dark:text-zinc-200 shadow-lg backdrop-blur-sm">YOLOv11</span>
    </div>
    <div class="absolute top-[18%] right-[0%] float-badge" style="animation-delay: 0.7s;">
      <span class="px-3 py-1.5 rounded-full bg-white/90 dark:bg-zinc-800/90 border border-zinc-200/60 dark:border-zinc-700/60 text-xs font-mono text-zinc-700 dark:text-zinc-200 shadow-lg backdrop-blur-sm">LangChain</span>
    </div>
    <div class="absolute top-[46%] left-[-4%] float-badge" style="animation-delay: 1.4s;">
      <span class="px-3 py-1.5 rounded-full bg-white/90 dark:bg-zinc-800/90 border border-zinc-200/60 dark:border-zinc-700/60 text-xs font-mono text-zinc-700 dark:text-zinc-200 shadow-lg backdrop-blur-sm">SAM 2</span>
    </div>
    <div class="absolute bottom-[18%] left-[8%] float-badge" style="animation-delay: 2.1s;">
      <span class="px-3 py-1.5 rounded-full bg-white/90 dark:bg-zinc-800/90 border border-zinc-200/60 dark:border-zinc-700/60 text-xs font-mono text-zinc-700 dark:text-zinc-200 shadow-lg backdrop-blur-sm">PyTorch</span>
    </div>
    <div class="absolute bottom-[6%] right-[14%] float-badge" style="animation-delay: 2.8s;">
      <span class="px-3 py-1.5 rounded-full bg-white/90 dark:bg-zinc-800/90 border border-zinc-200/60 dark:border-zinc-700/60 text-xs font-mono text-zinc-700 dark:text-zinc-200 shadow-lg backdrop-blur-sm">ChromaDB</span>
    </div>
  </div>
</section>

<style>
  @keyframes heroEnter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-anim-1 {
    animation: heroEnter 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }
  .hero-anim-2 {
    animation: heroEnter 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }
  .hero-anim-3 {
    animation: heroEnter 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }
  .hero-anim-4 {
    animation: heroEnter 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
  }
  .hero-anim-5 {
    animation: heroEnter 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  @keyframes floatBadge {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-12px); }
  }
  .float-badge {
    animation: floatBadge 5s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim-1, .hero-anim-2, .hero-anim-3, .hero-anim-4, .hero-anim-5 {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .float-badge {
      animation: none;
    }
  }
</style>
