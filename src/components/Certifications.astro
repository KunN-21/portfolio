---
const certs = [
  {
    title: "Machine Learning Specialization",
    org: "Coursera",
    period: "2023 - 2024",
    url: "https://coursera.org/verify/specialization/DNB7JFP47EMF",
  },
  {
    title: "TOEIC Listening & Reading",
    org: "ETS",
    score: "735 / 990",
    period: "Issued 06/2026 - Expires 06/2028",
  },
  {
    title: "TOEIC Speaking & Writing",
    org: "ETS",
    score: "280 / 400",
    period: "Issued 06/2026 - Expires 06/2028",
  },
];
---

<section class="py-24 px-6 md:px-10 lg:px-16">
  <div class="max-w-5xl mx-auto">
    <h2 class="reveal text-3xl md:text-4xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-12">
      Certifications
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {certs.map((c, i) => (
        <div class={`reveal stagger-${i + 1} hover-lift rounded-xl border border-zinc-200/30 dark:border-zinc-800/30 bg-white/40 dark:bg-zinc-900/40 p-6 flex flex-col`}>
          <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-2">{c.title}</h3>
          <p class="text-sm text-zinc-500 dark:text-zinc-500 mb-1">{c.org}</p>
          {c.score && <p class="font-mono text-sm font-bold text-accent mb-2">{c.score}</p>}
          <p class="text-xs text-zinc-400 dark:text-zinc-600 mt-auto">{c.period}</p>
          {c.url && (
            <a
              href={c.url}
              class="text-xs text-accent hover:text-accent-soft transition-colors no-underline mt-1"
            >
              Verify
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
