---
import { buildArchPath, type ProjectData } from "../data/projects";

interface Props {
  project: ProjectData;
  index: number;
}

const { project, index } = Astro.props;
const metricGradients: Record<string, string> = {
  blue: "metric-blue",
  teal: "metric-teal",
  indigo: "metric-indigo",
};
const paddedIndex = String(index + 1).padStart(2, "0");
const accentClass = index % 2 === 0
  ? "before:bg-blue-500 dark:before:bg-blue-400"
  : "before:bg-teal-500 dark:before:bg-teal-400";
---

<article class={`group relative isolate overflow-hidden rounded-xl border border-zinc-200/70 dark:border-zinc-800/70 bg-white/80 dark:bg-zinc-900/60 backdrop-blur-sm p-6 md:p-8 lg:p-10 transition-colors duration-300 ease-out hover:bg-white dark:hover:bg-zinc-900/80 before:absolute before:left-0 before:top-0 before:bottom-0 before:w-[3px] ${accentClass}`}>

  <!-- Header: year + title -->
  <header class="mb-6">
    <span class="block font-mono text-xs tracking-wider text-zinc-400 dark:text-zinc-600 mb-3">
      {project.year}
    </span>
    <h3 class="text-2xl md:text-3xl lg:text-4xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 leading-[1.05] mb-2">
      {project.title}
    </h3>
    <p class="text-base text-zinc-600 dark:text-zinc-400 leading-snug max-w-[52ch]">
      {project.subtitle}
    </p>
  </header>

  <!-- Metric strip: full-width divider + row of value/label pairs -->
  <div class="border-y border-zinc-200/70 dark:border-zinc-800/70 grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-zinc-200/70 dark:divide-zinc-800/70 mb-8">
    {project.metrics.map((m) => (
      <div class={`px-5 py-4 ${metricGradients[m.gradient] ?? "metric-blue"} rounded-none`}>
        <p class="font-mono text-sm md:text-base font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight mb-1 break-words">
          {m.value}
        </p>
        <p class="text-[11px] text-zinc-500 dark:text-zinc-500 uppercase tracking-[0.14em]">
          {m.label}
        </p>
      </div>
    ))}
  </div>

  <!-- Body grid: arch flow + side column -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-10 mb-8">
    <!-- Architecture flow (3/5 cols) -->
    <div class="lg:col-span-3 p-5 rounded-lg border border-zinc-200/60 dark:border-zinc-800/60 bg-zinc-50/60 dark:bg-zinc-950/40">
      <p class="text-[10px] font-medium text-zinc-400 dark:text-zinc-600 uppercase tracking-[0.18em] mb-4">
        Architecture
      </p>
      <Fragment set:html={buildArchPath(project.archFlow)} />
    </div>

    <!-- Tech stack (2/5 cols) -->
    <div class="lg:col-span-2 flex flex-col">
      <p class="text-[10px] font-medium text-zinc-400 dark:text-zinc-600 uppercase tracking-[0.18em] mb-4">
        Stack
      </p>
      <ul class="flex flex-wrap gap-1.5 font-mono text-xs">
        {project.techBadges.map((badge) => (
          <li class="px-2.5 py-1 rounded-md bg-zinc-100 dark:bg-zinc-800/60 text-zinc-700 dark:text-zinc-300 border border-zinc-200/80 dark:border-zinc-700/40">
            {badge}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Footer: divider + CTA -->
  <footer class="pt-5 border-t border-zinc-200/70 dark:border-zinc-800/70 flex items-center">
    <a
      href={project.githubUrl}
      class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent-soft transition-colors no-underline group/link"
    >
      <span>View source on GitHub</span>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200 group-hover/link:translate-x-0.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
    </a>
  </footer>
</article>
