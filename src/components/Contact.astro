---

<section id="contact" class="py-32 px-6 md:px-10 lg:px-16">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="reveal text-3xl md:text-5xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-6">
      Let's build something
    </h2>
    <p class="reveal stagger-1 text-lg text-zinc-600 dark:text-zinc-400 mb-10 max-w-[40ch] mx-auto leading-relaxed">
      Open to AI Engineer roles and collaboration on RAG, computer vision, or agentic AI projects.
    </p>
    <div class="reveal stagger-2 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="mailto:vukhanhnam.nv@gmail.com"
        class="group inline-flex items-center gap-2 px-8 py-4 rounded-full bg-accent text-white font-medium text-base hover:bg-accent-soft hover:-translate-y-1 hover:shadow-[0_10px_40px_rgba(59,130,246,0.5)] transition-all duration-300 no-underline"
      >
        Get in touch
        <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
      </a>
      <a
        href="https://github.com/KunN-21"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full border border-zinc-300 dark:border-zinc-700 text-zinc-800 dark:text-zinc-200 font-medium text-base hover:border-accent hover:text-accent hover:-translate-y-1 transition-all duration-300 no-underline"
      >
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/namvu21"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full border border-zinc-300 dark:border-zinc-700 text-zinc-800 dark:text-zinc-200 font-medium text-base hover:border-accent hover:text-accent hover:-translate-y-1 transition-all duration-300 no-underline"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>
