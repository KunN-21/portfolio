---
import MagneticCTA from "./MagneticCTA";
---

<section id="contact" class="py-32 px-6 md:px-10 lg:px-16">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="reveal text-3xl md:text-5xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-6">
      Let's build something
    </h2>
    <p class="reveal stagger-1 text-lg text-zinc-600 dark:text-zinc-400 mb-10 max-w-[40ch] mx-auto leading-relaxed">
      Open to AI Engineer roles and collaboration on RAG, computer vision, or agentic AI projects.
    </p>
    <div class="reveal stagger-2 flex flex-col sm:flex-row gap-4 justify-center">
      <MagneticCTA
        href="mailto:kunn21.nv@gmail.com"
        variant="primary"
        client:visible
      >
        Get in touch
      </MagneticCTA>
      <MagneticCTA
        href="https://github.com/KunN-21"
        variant="outline"
        external
        client:visible
      >
        GitHub
      </MagneticCTA>
      <MagneticCTA
        href="https://www.linkedin.com/in/namvu21"
        variant="outline"
        external
        client:visible
      >
        LinkedIn
      </MagneticCTA>
    </div>
  </div>
</section>
