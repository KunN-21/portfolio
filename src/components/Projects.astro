---
import StickyStack from "./StickyStack.tsx";
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../data/projects";
---

<section id="projects" class="py-24 px-6 md:px-10 lg:px-16">
  <div class="max-w-5xl mx-auto mb-12">
    <p class="text-sm font-medium tracking-widest uppercase text-accent mb-4">Projects</p>
    <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-zinc-100">
      What I've Built
    </h2>
  </div>

  <StickyStack client:load>
    {projects.map((p) => (
      <ProjectCard project={p} />
    ))}
  </StickyStack>
</section>
