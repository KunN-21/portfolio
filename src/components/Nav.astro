---
import ThemeToggle from "./ThemeToggle";
---

<nav class="nav-anim sticky top-0 z-50 h-16 flex items-center justify-between gap-4 px-4 sm:px-6 md:px-10 lg:px-16 bg-zinc-50/80 dark:bg-zinc-950/80 backdrop-blur-md border-b border-zinc-200/50 dark:border-zinc-800/50" role="navigation" aria-label="Main navigation">
  <a href="#hero-title" class="nav-anim-1 text-lg font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 no-underline whitespace-nowrap">
    KunN21
  </a>

  <div class="nav-anim-2 flex items-center gap-3 sm:gap-6 min-w-0">
    <a href="#about" class="link-underline text-xs sm:text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors no-underline whitespace-nowrap">About</a>
    <a href="#projects" class="link-underline text-xs sm:text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors no-underline whitespace-nowrap">Projects</a>
    <a href="#contact" class="link-underline text-xs sm:text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors no-underline whitespace-nowrap">Contact</a>
    <ThemeToggle client:visible />
  </div>
</nav>

<style>
  @keyframes navSlideDown {
    from {
      opacity: 0;
      transform: translateY(-100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nav-anim {
    animation: navSlideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-anim-1 {
    animation: navSlideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s backwards;
  }

  .nav-anim-2 {
    animation: navSlideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s backwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-anim, .nav-anim-1, .nav-anim-2 {
      animation: none;
    }
  }
</style>
