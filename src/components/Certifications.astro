---
const certs = [
  {
    title: "Machine Learning Specialization",
    org: "Coursera",
    period: "2023 – 2024",
    url: "https://coursera.org/verify/specialization/DNB7JFP47EMF",
  },
  {
    title: "TOEIC Listening & Reading",
    org: "ETS",
    score: "735 / 990",
    period: "Issued 06/2026 · Expires 06/2028",
  },
  {
    title: "TOEIC Speaking & Writing",
    org: "ETS",
    score: "280 / 400",
    period: "Issued 06/2026 · Expires 06/2028",
  },
];
---

<section class="py-24 px-6 md:px-10 lg:px-16">
  <div class="max-w-3xl mx-auto">
    <h2 class="reveal text-3xl md:text-4xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-10">
      Certifications
    </h2>

    <dl class="divide-y divide-zinc-200/70 dark:divide-zinc-800/70 border-y border-zinc-200/70 dark:border-zinc-800/70">
      {certs.map((c, i) => (
        <div class={`reveal stagger-${i + 1} py-5 grid grid-cols-12 gap-4 items-baseline`}>
          <dt class="col-span-12 sm:col-span-5 text-base font-semibold text-zinc-900 dark:text-zinc-100 leading-snug">
            {c.title}
          </dt>
          <dd class="col-span-7 sm:col-span-3 font-mono text-xs text-zinc-500 dark:text-zinc-500 uppercase tracking-wider">
            {c.org}
          </dd>
          <dd class="col-span-5 sm:col-span-2 font-mono text-xs text-zinc-500 dark:text-zinc-500">
            {c.period}
          </dd>
          <dd class="col-span-12 sm:col-span-2 sm:text-right">
            {c.score && (
              <span class="font-mono text-sm font-bold text-accent">{c.score}</span>
            )}
            {c.url && !c.score && (
              <a
                href={c.url}
                class="text-xs text-accent hover:text-accent-soft transition-colors no-underline"
              >
                Verify
              </a>
            )}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>