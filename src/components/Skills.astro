---
const skillGroups = [
  {
    label: "AI / Computer Vision",
    badges: ["YOLOv8", "YOLOv11", "SAM 2", "BoT-SORT", "ReID", "MediaPipe", "OpenCV", "PyTorch"],
    size: "md",
    gradient: "metric-blue",
    accent: "border-l-blue-400/60",
    stat: "86.3% mAP@50",
    statLabel: "custom YOLO model",
  },
  {
    label: "LLMs / NLP",
    badges: ["RAG", "LangChain", "ChromaDB", "BM25", "Ollama", "OpenRouter", "Semantic Chunking", "Agentic RAG"],
    size: "lg",
    gradient: "metric-teal",
    accent: "border-l-teal-400/60",
  },
  {
    label: "Programming & Tools",
    badges: ["Python", "NumPy", "Pandas", "Streamlit", "C/C++", "Docker", "Linux/WSL", "Git", "pytest"],
    size: "md",
    gradient: "metric-indigo",
    accent: "border-l-indigo-400/60",
    stat: "30+ FPS",
    statLabel: "edge inference",
  },
];

function tileClass(size: string) {
  if (size === "lg") return "col-span-2 row-span-2";
  return "col-span-1 row-span-1";
}
---

<section class="pt-24 pb-24 lg:pt-32 lg:pb-24 px-6 md:px-10 lg:px-16 relative z-10 bg-zinc-50 dark:bg-zinc-950">
  <div class="max-w-5xl mx-auto">
    <h2 class="reveal text-3xl md:text-4xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-12">
      Tech Stack
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[minmax(180px,auto)]">
      {skillGroups.map((group, i) => (
        <div
          class={`reveal stagger-${i + 2} hover-lift rounded-xl border border-zinc-200/40 dark:border-zinc-800/40 bg-white/70 dark:bg-zinc-900/70 backdrop-blur-sm shadow-sm p-6 ${group.gradient} ${tileClass(group.size)} ${group.accent} flex flex-col`}
        >
          <div>
            <h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-3">{group.label}</h3>
            <div class="flex flex-wrap gap-1.5">
              {group.badges.map((b) => (
                <span class="px-2.5 py-1 rounded-md bg-zinc-100 dark:bg-zinc-800/60 text-xs text-zinc-700 dark:text-zinc-300">
                  {b}
                </span>
              ))}
            </div>
          </div>

          {group.size === "lg" && (
            <div class="mt-auto pt-5">
              <div class="rounded-lg bg-zinc-900/95 dark:bg-black/80 border border-zinc-700/50 p-3 font-mono text-[11px] leading-relaxed shadow-inner">
                <div class="flex items-center gap-1.5 mb-2 pb-2 border-b border-zinc-700/50">
                  <span class="w-1.5 h-1.5 rounded-full bg-red-500/80"></span>
                  <span class="w-1.5 h-1.5 rounded-full bg-yellow-500/80"></span>
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500/80"></span>
                  <span class="ml-2 text-zinc-500 text-[10px]">agent_query.py</span>
                </div>
                <div class="text-zinc-400">
                  <span class="text-purple-400">query</span> = <span class="text-amber-300">"hybrid"</span>
                </div>
                <div class="text-zinc-500">
                  <span class="text-blue-400">retriever</span>.search(query)
                </div>
                <div class="text-zinc-500 ml-2">
                  → <span class="text-teal-300">ChromaDB</span> + <span class="text-teal-300">BM25</span>
                </div>
                <div class="text-zinc-500">
                  <span class="text-blue-400">llm</span>.generate(context)
                </div>
                <div class="flex items-center gap-1.5 mt-2 pt-2 border-t border-zinc-700/50 text-zinc-400">
                  <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"></span>
                  <span class="text-[10px]">agentic loop running...</span>
                </div>
              </div>
              <div class="flex items-center justify-between mt-3 text-xs">
                <span class="text-zinc-500">currently exploring</span>
                <span class="px-2 py-0.5 rounded-full bg-teal-500/10 border border-teal-500/30 text-teal-600 dark:text-teal-300 font-mono">agentic RAG</span>
              </div>
            </div>
          )}

          {group.size === "md" && group.stat && (
            <div class="mt-auto pt-3 flex items-baseline gap-2">
              <span class="font-mono text-2xl font-bold text-accent tracking-tight">{group.stat}</span>
              <span class="text-xs text-zinc-500">{group.statLabel}</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
