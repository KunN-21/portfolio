---
const skillGroups = [
  {
    label: "AI / Computer Vision",
    badges: ["YOLOv8", "YOLOv11", "SAM 2", "BoT-SORT", "ReID", "MediaPipe", "OpenCV", "PyTorch"],
    size: "md",
    gradient: "metric-blue",
  },
  {
    label: "LLMs / NLP",
    badges: ["RAG", "LangChain", "ChromaDB", "BM25", "Ollama", "OpenRouter", "Semantic Chunking", "Agentic RAG"],
    size: "lg",
    gradient: "metric-teal",
  },
  {
    label: "Programming & Tools",
    badges: ["Python", "NumPy", "Pandas", "Streamlit", "C/C++", "Docker", "Linux/WSL", "Git", "pytest"],
    size: "md",
    gradient: "metric-indigo",
  },
];

function tileClass(size: string) {
  if (size === "lg") return "col-span-2 row-span-2";
  return "col-span-1 row-span-1";
}
---

<section class="py-24 px-6 md:px-10 lg:px-16">
  <div class="max-w-5xl mx-auto">
    <p class="text-sm font-medium tracking-widest uppercase text-accent mb-4">Skills</p>
    <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-zinc-100 mb-12">
      Tech Stack
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[minmax(140px,auto)]">
      {skillGroups.map((group) => (
        <div
          class={`rounded-xl border border-zinc-800/30 p-6 ${group.gradient} ${tileClass(group.size)} flex flex-col justify-between`}
        >
          <h3 class="text-lg font-bold text-zinc-100 mb-4">{group.label}</h3>
          <div class="flex flex-wrap gap-1.5">
            {group.badges.map((b) => (
              <span class="px-2.5 py-1 rounded-md bg-zinc-800/60 text-xs text-zinc-300">
                {b}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
