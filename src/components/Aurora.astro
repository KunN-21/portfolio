---
// 3 aurora orbs — CSS-only drift, no JS animation. honors prefers-reduced-motion.
---

<div class="fixed inset-0 overflow-hidden pointer-events-none -z-10" aria-hidden="true">
  <!-- Orb 1: blue, top-right -->
  <div
    class="aurora-orb"
    style="
      width: min(70vw, 900px);
      height: min(70vw, 900px);
      top: -30%;
      right: -20%;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.25), transparent 65%);
      animation: aurora-drift-1 24s ease-in-out infinite alternate;
    "
  ></div>

  <!-- Orb 2: teal, bottom-left -->
  <div
    class="aurora-orb"
    style="
      width: min(60vw, 800px);
      height: min(60vw, 800px);
      bottom: -25%;
      left: -15%;
      background: radial-gradient(circle, rgba(20, 184, 166, 0.22), transparent 65%);
      animation: aurora-drift-2 28s ease-in-out infinite alternate;
    "
  ></div>

  <!-- Orb 3: indigo, center-top -->
  <div
    class="aurora-orb"
    style="
      width: min(55vw, 700px);
      height: min(55vw, 700px);
      top: 40%;
      left: 55%;
      background: radial-gradient(circle, rgba(79, 70, 229, 0.18), transparent 65%);
      animation: aurora-drift-3 32s ease-in-out infinite alternate;
    "
  ></div>
</div>

<style is:global>
  @keyframes aurora-drift-1 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-5%, 8%) scale(1.08); }
  }
  @keyframes aurora-drift-2 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(6%, -6%) scale(1.06); }
  }
  @keyframes aurora-drift-3 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-3%, -5%) scale(1.1); }
  }

  @media (prefers-reduced-motion: reduce) {
    @keyframes aurora-drift-1,
    @keyframes aurora-drift-2,
    @keyframes aurora-drift-3 {
      0%, 100% { transform: none; }
    }
  }

  :root:not(.dark) .aurora-orb {
    opacity: 0.08;
  }
</style>
